{
  "version": "2026.1",
  "standard": "KWCAG 2.2 (한국형 웹 콘텐츠 접근성 지침 2.2)",
  "lastUpdated": "2026-03-26",
  "source": "https://www.wa.or.kr/kwcag22",
  "rules": [
    {
      "id": "A-01",
      "title": "img alt 속성 누락",
      "description": "모든 이미지에는 대체 텍스트(alt 속성)를 제공해야 합니다. 스크린 리더 사용자가 이미지의 의미를 이해할 수 있도록 합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "img:not([alt])",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "대체 텍스트",
      "autoFixable": true
    },
    {
      "id": "A-02",
      "title": "input label 미연결",
      "description": "모든 입력 요소에는 연결된 label이 있어야 합니다. input에 id가 없거나 대응하는 label[for]이 없으면 접근성이 저하됩니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "input:not([id])",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "입력 서식",
      "autoFixable": true
    },
    {
      "id": "A-03",
      "title": "빈 링크/버튼 텍스트",
      "description": "링크와 버튼에는 텍스트 콘텐츠가 있어야 합니다. 빈 링크나 버튼은 스크린 리더에서 목적을 알 수 없습니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "a:empty, button:empty",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "링크/버튼",
      "autoFixable": false
    },
    {
      "id": "A-04",
      "title": "table caption/th 누락",
      "description": "데이터 테이블에는 caption과 th 요소가 있어야 합니다. 테이블의 목적과 구조를 명확히 전달합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "table:not(:has(caption)), table:not(:has(th))",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "테이블",
      "autoFixable": false
    },
    {
      "id": "A-05",
      "title": "html lang 속성 누락",
      "description": "html 요소에 lang 속성을 지정하여 문서의 기본 언어를 명시해야 합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "html:not([lang])",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "언어 명시",
      "autoFixable": true
    },
    {
      "id": "A-06",
      "title": "tabindex 양수값 사용",
      "description": "tabindex에 양수 값을 사용하면 자연스러운 탭 순서가 깨질 수 있습니다. 0 또는 -1만 사용해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "[tabindex]",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "키보드 접근",
      "autoFixable": false
    },
    {
      "id": "A-07",
      "title": "자동재생 미디어",
      "description": "자동 재생되는 미디어는 사용자에게 혼란을 줄 수 있습니다. autoplay 속성 사용을 지양해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "[autoplay]",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "미디어",
      "autoFixable": false
    },
    {
      "id": "A-08",
      "title": "skip navigation 누락",
      "description": "페이지 상단에 본문 바로가기 링크(skip navigation)가 있어야 합니다. 첫 번째 링크가 #content 등으로 연결되어야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "<a[^>]+href=[\"']#(content|main|skip)[\"']",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "반복 영역",
      "autoFixable": false
    },
    {
      "id": "A-09",
      "title": "명도대비 하드코딩 색상",
      "description": "인라인 스타일에서 직접 색상을 지정하면 명도 대비를 검증하기 어렵습니다. CSS 클래스를 사용해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "style=\".*color:.*#",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs", "css"],
      "category": "명도 대비",
      "autoFixable": false
    },
    {
      "id": "A-10",
      "title": "키보드 트랩 가능성",
      "description": "onkeydown 또는 onkeypress를 사용할 때 onkeyup이 없으면 키보드 트랩이 발생할 수 있습니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "on(keydown|keypress)\\s*=",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "키보드 접근",
      "autoFixable": false
    },
    {
      "id": "A-11",
      "title": "title 태그 누락/빈값",
      "description": "모든 페이지에는 의미 있는 title 태그가 있어야 합니다. 빈 title이나 누락된 title은 접근성을 저해합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "<title>\\s*</title>|<title\\s*/>",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "페이지 제목",
      "autoFixable": false
    },
    {
      "id": "A-12",
      "title": "iframe title 누락",
      "description": "iframe에는 title 속성을 제공하여 프레임의 내용을 설명해야 합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "iframe:not([title])",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "프레임",
      "autoFixable": true
    },
    {
      "id": "A-13",
      "title": "깜빡임/번쩍임 콘텐츠",
      "description": "blink, marquee 등 깜빡이는 콘텐츠는 광과민성 발작을 유발할 수 있어 사용이 금지됩니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "blink, marquee",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "깜빡임 방지",
      "autoFixable": false
    },
    {
      "id": "A-14",
      "title": "role/aria 속성 오사용",
      "description": "ARIA role과 aria-* 속성이 WAI-ARIA 명세에 맞게 올바르게 사용되어야 합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "[role], [aria-*]",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "ARIA",
      "autoFixable": false
    },
    {
      "id": "A-15",
      "title": "페이지 제목 중복",
      "description": "각 페이지의 title은 고유해야 합니다. 동일한 제목을 가진 여러 페이지가 있으면 구분이 어렵습니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "<title>[^<]+</title>",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "페이지 제목",
      "autoFixable": false
    },
    {
      "id": "A-16",
      "title": "링크 텍스트 불명확",
      "description": "링크 텍스트가 '여기', '클릭', 'more', 'click here' 등 모호한 표현이면 안 됩니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "<a[^>]*>\\s*(여기|클릭|more|click here|자세히|read more|link)\\s*</a>",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "링크/버튼",
      "autoFixable": false
    },
    {
      "id": "A-17",
      "title": "fieldset/legend 누락",
      "description": "라디오 버튼이나 체크박스 그룹은 fieldset과 legend로 그룹화해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "input[type='radio'], input[type='checkbox']",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "입력 서식",
      "autoFixable": false
    },
    {
      "id": "A-18",
      "title": "텍스트 크기 고정(px)",
      "description": "폰트 크기를 px 단위로 지정하면 사용자가 텍스트 크기를 조절할 수 없습니다. em, rem, % 등 상대 단위를 사용해야 합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "font-size\\s*:\\s*\\d+px",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs", "css"],
      "category": "텍스트 크기",
      "autoFixable": false
    },
    {
      "id": "A-19",
      "title": "반복 영역 건너뛰기 미제공",
      "description": "반복되는 네비게이션 영역에는 건너뛰기 링크를 제공하여 키보드 사용자가 본문으로 직접 이동할 수 있어야 합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "<nav",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "반복 영역",
      "autoFixable": false
    },
    {
      "id": "A-20",
      "title": "초점 이동 순서 비논리적",
      "description": "탭 키로 이동하는 순서가 논리적이고 직관적이어야 합니다. tabindex 값의 순서를 분석합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "[tabindex]",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "키보드 접근",
      "autoFixable": false
    },
    {
      "id": "A-21",
      "title": "대체 텍스트 적절성",
      "description": "이미지의 alt 텍스트가 이미지의 의미와 기능을 적절히 설명하고 있는지 검사합니다. 단순 파일명이나 무의미한 텍스트가 아닌 의미 있는 대체 텍스트여야 합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "대체 텍스트",
      "autoFixable": false
    },
    {
      "id": "A-22",
      "title": "논리적 제목 구조",
      "description": "h1~h6 제목 요소가 논리적 순서로 사용되어야 합니다. 제목 레벨을 건너뛰지 않아야 합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "콘텐츠 구조",
      "autoFixable": false
    },
    {
      "id": "A-23",
      "title": "오류 안내 충분성",
      "description": "폼 제출 시 오류가 발생하면 사용자에게 오류 원인과 해결 방법을 충분히 안내해야 합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "js"],
      "category": "입력 서식",
      "autoFixable": false
    },
    {
      "id": "A-24",
      "title": "텍스트 간격 적절성",
      "description": "텍스트의 줄 간격, 단어 간격, 문자 간격이 적절하여 가독성이 확보되어야 합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "css"],
      "category": "텍스트 크기",
      "autoFixable": false
    },
    {
      "id": "A-25",
      "title": "초점 표시 가시성",
      "description": "키보드 초점이 이동할 때 시각적으로 명확히 표시되어야 합니다. outline:none 등으로 초점 표시를 제거하면 안 됩니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "css"],
      "category": "키보드 접근",
      "autoFixable": false
    },
    {
      "id": "A-26",
      "title": "의미 있는 순서",
      "description": "콘텐츠의 시각적 순서와 DOM 순서가 일치하여 의미 있는 읽기 순서를 유지해야 합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "css"],
      "category": "콘텐츠 구조",
      "autoFixable": false
    },
    {
      "id": "A-27",
      "title": "접근 가능한 이름",
      "description": "모든 인터랙티브 요소에 접근 가능한 이름(accessible name)이 제공되어야 합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "ARIA",
      "autoFixable": false
    },
    {
      "id": "A-28",
      "title": "포인터 제스처 대안",
      "description": "복잡한 포인터 제스처(드래그, 멀티터치 등)를 사용하는 기능에 단순한 대안이 제공되어야 합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "js"],
      "category": "입력 방식",
      "autoFixable": false
    },
    {
      "id": "A-29",
      "title": "대상 크기 적절성",
      "description": "터치 대상의 크기가 최소 24x24 CSS 픽셀 이상이어야 합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "css"],
      "category": "입력 방식",
      "autoFixable": false
    },
    {
      "id": "A-30",
      "title": "일관된 탐색",
      "description": "사이트 내 반복되는 탐색 메커니즘이 일관된 순서와 구조로 제공되어야 합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "반복 영역",
      "autoFixable": false
    },
    {
      "id": "A-31",
      "title": "상태 메시지 제공",
      "description": "동적으로 나타나는 상태 메시지가 접근성 API를 통해 스크린 리더에 전달되어야 합니다(aria-live 등).",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "js"],
      "category": "상태 메시지",
      "autoFixable": false
    },
    {
      "id": "A-32",
      "title": "드래그 대안",
      "description": "드래그 앤 드롭으로만 조작 가능한 기능에 키보드 등 대안적 방법이 제공되어야 합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["html", "jsp", "vue", "ejs", "js"],
      "category": "입력 방식",
      "autoFixable": false
    },
    {
      "id": "A-33",
      "title": "중복 입력 방지",
      "description": "동일한 정보를 여러 번 입력하도록 요구하지 않아야 합니다. 자동완성이나 이전 입력값 재활용을 지원해야 합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
