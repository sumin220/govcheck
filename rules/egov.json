{
  "version": "2026.1",
  "standard": "전자정부 표준프레임워크 호환성 점검",
  "lastUpdated": "2026-03-26",
  "source": "https://www.egovframe.go.kr",
  "rules": [
    {
      "id": "E-01",
      "title": "전자정부 프레임워크 JAR 존재",
      "description": "전자정부 표준프레임워크 필수 JAR 파일(egovframework)이 프로젝트에 포함되어 있어야 합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "egovframework",
      "patternType": "file-check",
      "fileTypes": ["jar", "xml", "gradle", "pom"],
      "category": "프레임워크 구조",
      "autoFixable": false
    },
    {
      "id": "E-02",
      "title": "egovframework.rte import",
      "description": "전자정부 표준프레임워크 런타임 환경(egovframework.rte) import가 사용되어야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "import\\s+egovframework\\.rte\\.",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "프레임워크 구조",
      "autoFixable": false
    },
    {
      "id": "E-03",
      "title": "DAO가 EgovAbstractMapper 상속",
      "description": "DAO 클래스는 EgovAbstractMapper 또는 EgovAbstractDAO를 상속해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "extends\\s+(EgovAbstractMapper|EgovAbstractDAO)",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "데이터 접근",
      "autoFixable": false
    },
    {
      "id": "E-04",
      "title": "Service 인터페이스 패턴",
      "description": "서비스 계층은 인터페이스와 구현체로 분리되어야 합니다. Service 인터페이스를 정의하고 Impl에서 구현합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "implements\\s+\\w+Service",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "서비스 구조",
      "autoFixable": false
    },
    {
      "id": "E-05",
      "title": "globals.properties 존재",
      "description": "전자정부 표준프레임워크 프로젝트에는 globals.properties 설정 파일이 있어야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "globals.properties",
      "patternType": "file-check",
      "fileTypes": ["properties"],
      "category": "설정 파일",
      "autoFixable": false
    },
    {
      "id": "E-06",
      "title": "표준 디렉토리 구조",
      "description": "전자정부 표준프레임워크의 표준 디렉토리 구조(src/main/java, src/main/resources, src/main/webapp)를 따라야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "src/main/java,src/main/resources,src/main/webapp",
      "patternType": "structure",
      "fileTypes": [],
      "category": "프로젝트 구조",
      "autoFixable": false
    },
    {
      "id": "E-07",
      "title": "Spring 설정 XML 네임스페이스",
      "description": "Spring 설정 XML에서 올바른 네임스페이스(beans, context, mvc 등)가 선언되어야 합니다.",
      "severity": "info",
      "tier": "T1",
      "pattern": "xmlns:context=|xmlns:mvc=|xmlns:aop=",
      "patternType": "regex",
      "fileTypes": ["xml"],
      "category": "설정 파일",
      "autoFixable": false
    },
    {
      "id": "E-08",
      "title": "MyBatis 설정 위치",
      "description": "MyBatis 매퍼 설정 파일이 올바른 위치에 존재해야 합니다.",
      "severity": "info",
      "tier": "T1",
      "pattern": "mapper-locations|mapperLocations|sql-map",
      "patternType": "file-check",
      "fileTypes": ["xml", "properties", "yml", "yaml"],
      "category": "설정 파일",
      "autoFixable": false
    }
  ]
}
