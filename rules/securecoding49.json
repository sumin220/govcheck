{
  "version": "2026.1",
  "standard": "행정안전부 시큐어코딩 가이드 49개 항목",
  "lastUpdated": "2026-03-26",
  "source": "https://www.mois.go.kr/securecoding",
  "rules": [
    {
      "id": "S-01",
      "title": "SQL 삽입",
      "description": "외부 입력값을 그대로 SQL 쿼리에 연결하면 SQL 삽입 공격이 가능합니다. PreparedStatement를 사용해야 합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "\".*\\+\\s*\\w+.*\"",
      "patternType": "regex",
      "fileTypes": ["java", "jsp", "xml"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-02",
      "title": "크로스사이트 스크립팅 (c:out 미사용)",
      "description": "JSP에서 EL 표현식을 c:out 없이 직접 출력하면 XSS 공격에 취약합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "\\$\\{[^}]+\\}",
      "patternType": "regex",
      "fileTypes": ["jsp"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": true
    },
    {
      "id": "S-03",
      "title": "운영체제 명령어 삽입",
      "description": "Runtime.exec()을 사용하여 외부 입력값으로 OS 명령어를 실행하면 명령어 삽입 공격이 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "Runtime\\.getRuntime\\(\\)\\.exec\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-04",
      "title": "경로 조작",
      "description": "외부 입력값을 파일 경로에 직접 사용하면 경로 조작을 통한 임의 파일 접근이 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "new File\\(.*\\+",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-05",
      "title": "크로스사이트 스크립팅 (표현식 태그)",
      "description": "JSP 표현식 태그에서 request.getParameter를 직접 출력하면 XSS 공격에 취약합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "<%=.*request\\.getParameter",
      "patternType": "regex",
      "fileTypes": ["jsp"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-06",
      "title": "LDAP 삽입",
      "description": "외부 입력값을 LDAP 쿼리에 직접 사용하면 LDAP 삽입 공격이 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "SearchControls|DirContext.*search",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-07",
      "title": "XML 삽입",
      "description": "XMLReader나 SAXParser에서 외부 엔티티 처리를 비활성화하지 않으면 XXE 공격에 취약합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "XMLReader|SAXParser",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-08",
      "title": "HTTP 응답 분할",
      "description": "HTTP 응답 헤더에 외부 입력값을 직접 사용하면 응답 분할 공격이 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "response\\.setHeader\\(.*\\+",
      "patternType": "regex",
      "fileTypes": ["java", "jsp"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-09",
      "title": "정수 오버플로우",
      "description": "정수 연산 결과가 범위를 초과할 수 있습니다. 연산 전 범위 검증이 필요합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "Integer\\.MAX_VALUE|Integer\\.MIN_VALUE|\\(int\\)\\s*\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-10",
      "title": "버퍼 오버플로우",
      "description": "배열이나 버퍼의 크기를 검증하지 않고 사용하면 버퍼 오버플로우가 발생할 수 있습니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "new byte\\[.*\\]|new char\\[.*\\]",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-11",
      "title": "포맷 스트링 삽입",
      "description": "외부 입력값을 String.format의 포맷 문자열에 사용하면 포맷 스트링 공격이 가능합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "String\\.format\\(.*\\+",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-12",
      "title": "XPATH 삽입",
      "description": "외부 입력값을 XPath 쿼리에 직접 사용하면 XPATH 삽입 공격이 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "XPathExpression.*compile\\(.*\\+",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-13",
      "title": "크로스사이트 요청 위조",
      "description": "CSRF 토큰이 누락되면 사용자 모르게 요청이 위조될 수 있습니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "<form[^>]*method=[\"']post[\"'][^>]*>(?:(?!csrf|_token|_csrf).)*</form>",
      "patternType": "regex",
      "fileTypes": ["html", "jsp"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-14",
      "title": "신뢰되지 않는 URL 리다이렉트",
      "description": "외부 입력값을 리다이렉트 URL로 사용하면 피싱 등에 악용될 수 있습니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "response\\.sendRedirect\\(.*request",
      "patternType": "regex",
      "fileTypes": ["java", "jsp"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-15",
      "title": "위험한 형식 파일 업로드",
      "description": "업로드 파일의 확장자와 내용을 검증하지 않으면 악성 파일이 실행될 수 있습니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "MultipartFile|FileUpload|Part\\.getInputStream",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "입력데이터 검증 및 표현",
      "autoFixable": false
    },
    {
      "id": "S-16",
      "title": "하드코딩된 비밀번호",
      "description": "소스 코드에 비밀번호를 직접 기입하면 소스 유출 시 보안 사고가 발생합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "(password|passwd|pwd)\\s*=\\s*\"[^\"]+\"",
      "patternType": "regex",
      "fileTypes": ["java", "jsp", "properties", "xml", "yml", "yaml"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-17",
      "title": "취약한 암호화 알고리즘",
      "description": "MD5, SHA-1, DES 등 취약한 암호화 알고리즘을 사용하면 안 됩니다. SHA-256 이상 또는 AES를 사용해야 합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "getInstance\\(\\s*\"(MD5|SHA-1|DES)\"",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-18",
      "title": "솔트 없는 해시",
      "description": "해시 함수 사용 시 솔트(salt)를 추가하지 않으면 레인보우 테이블 공격에 취약합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "MessageDigest\\.getInstance",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-19",
      "title": "부적절한 키 크기",
      "description": "암호화 키 크기가 너무 작으면 무차별 대입 공격에 취약합니다. 충분한 키 길이를 사용해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "KeyGenerator.*init\\([0-9]{1,2}\\)",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-20",
      "title": "부적절한 인증서 검증",
      "description": "TrustManager에서 인증서 검증을 생략하면 중간자 공격에 취약합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "TrustManager.*checkServerTrusted.*return",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-21",
      "title": "하드코딩된 암호화 키",
      "description": "암호화 키를 소스 코드에 직접 기입하면 소스 유출 시 암호화가 무력화됩니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "SecretKeySpec\\(.*\\.getBytes\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-22",
      "title": "민감정보 평문 저장",
      "description": "비밀번호 등 민감 정보를 암호화하지 않고 평문으로 저장하면 안 됩니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "(setPassword|setPasswd)\\s*\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-23",
      "title": "민감정보 평문 전송",
      "description": "HTTP를 통해 민감 정보를 전송하면 네트워크 스니핑에 취약합니다. HTTPS를 사용해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "http://",
      "patternType": "regex",
      "fileTypes": ["java", "jsp", "properties", "xml", "yml", "yaml"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-24",
      "title": "쿠키 보안 속성 미설정",
      "description": "쿠키에 Secure 플래그를 설정하지 않으면 HTTP 연결에서도 쿠키가 전송됩니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "new Cookie\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-25",
      "title": "쿠키 HttpOnly 미설정",
      "description": "쿠키에 HttpOnly 플래그를 설정하지 않으면 JavaScript로 쿠키에 접근할 수 있어 XSS에 취약합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "new Cookie\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-26",
      "title": "세션 고정",
      "description": "로그인 처리 시 기존 세션을 무효화하지 않으면 세션 고정 공격에 취약합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "session\\.setAttribute|getSession\\(",
      "patternType": "regex",
      "fileTypes": ["java", "jsp"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-27",
      "title": "부적절한 인가",
      "description": "사용자 권한 검증이 적절히 이루어지지 않으면 비인가 접근이 가능합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-28",
      "title": "접근 제어 누락",
      "description": "중요 기능에 대한 접근 제어가 누락되면 비인가 사용자가 기능을 실행할 수 있습니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-29",
      "title": "부적절한 비밀번호 정책",
      "description": "비밀번호 복잡도, 길이, 변경 주기 등의 정책이 적절히 적용되어야 합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["java", "properties", "xml"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-30",
      "title": "재인증 누락",
      "description": "중요 거래나 설정 변경 시 재인증을 요구하지 않으면 세션 탈취에 취약합니다.",
      "severity": "warning",
      "tier": "T3",
      "pattern": "",
      "patternType": "claude",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-31",
      "title": "안전하지 않은 난수",
      "description": "java.util.Random은 예측 가능한 난수를 생성합니다. 보안 용도에는 SecureRandom을 사용해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "new Random\\(\\)",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "보안기능",
      "autoFixable": false
    },
    {
      "id": "S-32",
      "title": ".run() 직접 호출",
      "description": "Thread의 run()을 직접 호출하면 새 스레드가 생성되지 않습니다. start()를 사용해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "\\.run\\(\\)",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "시간 및 상태",
      "autoFixable": false
    },
    {
      "id": "S-33",
      "title": "경쟁 조건",
      "description": "공유 가변 상태에 대한 동기화 없이 접근하면 경쟁 조건이 발생할 수 있습니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "static\\s+(?!final)\\w+\\s+\\w+\\s*=",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "시간 및 상태",
      "autoFixable": false
    },
    {
      "id": "S-34",
      "title": "빈 catch 블록",
      "description": "catch 블록이 비어있으면 예외가 무시되어 오류를 감지할 수 없습니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "catch\\s*\\([^)]*\\)\\s*\\{\\s*\\}",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "에러처리",
      "autoFixable": true
    },
    {
      "id": "S-35",
      "title": "에러 정보 노출 (printStackTrace)",
      "description": "printStackTrace()는 시스템 정보를 노출시킵니다. 로깅 프레임워크를 사용해야 합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "\\.printStackTrace\\(\\)",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "에러처리",
      "autoFixable": true
    },
    {
      "id": "S-36",
      "title": "예외 상세정보 응답 노출",
      "description": "예외 메시지를 HTTP 응답에 직접 출력하면 시스템 내부 정보가 노출됩니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "response.*write.*getMessage|e\\.toString",
      "patternType": "regex",
      "fileTypes": ["java", "jsp"],
      "category": "에러처리",
      "autoFixable": false
    },
    {
      "id": "S-37",
      "title": "null 포인터 역참조",
      "description": "null일 수 있는 객체를 검증 없이 사용하면 NullPointerException이 발생합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "\\.get\\(.*\\)\\.",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "코드오류",
      "autoFixable": false
    },
    {
      "id": "S-38",
      "title": "자원 미해제",
      "description": "Connection, InputStream 등의 자원을 사용 후 close() 하지 않으면 자원 누수가 발생합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "new\\s+(FileInputStream|FileOutputStream|Connection|BufferedReader|PrintWriter)\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "코드오류",
      "autoFixable": false
    },
    {
      "id": "S-39",
      "title": "equals/hashCode 미구현",
      "description": "equals()를 오버라이드하면 hashCode()도 함께 오버라이드해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "public\\s+boolean\\s+equals\\s*\\(",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "코드오류",
      "autoFixable": false
    },
    {
      "id": "S-40",
      "title": "finalize() 사용",
      "description": "finalize() 메서드는 예측 불가능하며 보안 취약점을 유발할 수 있습니다. 사용을 피해야 합니다.",
      "severity": "warning",
