{
  "version": "2026.1",
  "standard": "KISA 주요정보통신기반시설 + OWASP Top 10 2025",
  "lastUpdated": "2026-03-26",
  "source": "https://www.kisa.or.kr/2060204/form?postSeq=12",
  "rules": [
    {
      "id": "V-01",
      "title": "SSI 인젝션",
      "description": "SSI(Server Side Include) 태그가 사용자 입력에 의해 삽입되면 원격 명령 실행이 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "<!--#(exec|include)",
      "patternType": "regex",
      "fileTypes": ["jsp", "html"],
      "category": "입력데이터 검증",
      "autoFixable": false
    },
    {
      "id": "V-02",
      "title": "디렉토리 인덱싱",
      "description": "디렉토리 리스팅이 활성화되어 있으면 서버의 파일 구조가 노출될 수 있습니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": null,
      "patternType": "xml-check",
      "xmlCheck": "directory-listing",
      "fileTypes": ["xml"],
      "category": "정보 노출",
      "autoFixable": true,
      "autoFixTemplate": "<init-param><param-name>listings</param-name><param-value>false</param-value></init-param>"
    },
    {
      "id": "V-03",
      "title": "정보 누출 (에러페이지 미설정)",
      "description": "web.xml에 에러 페이지가 설정되지 않으면 서버 정보가 노출될 수 있습니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": null,
      "patternType": "xml-check",
      "xmlCheck": "error-page",
      "fileTypes": ["xml"],
      "category": "정보 노출",
      "autoFixable": true,
      "autoFixTemplate": "<error-page><error-code>404</error-code><location>/error/404.jsp</location></error-page>"
    },
    {
      "id": "V-04",
      "title": "약한 문자열 강도",
      "description": "비밀번호 길이 제한이 너무 짧거나 복잡도 검증이 없으면 무차별 대입 공격에 취약합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "password.*length.*[<][456]",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "인증 및 세션",
      "autoFixable": false
    },
    {
      "id": "V-05",
      "title": "취약한 패스워드 복구",
      "description": "패스워드 복구 시 다중 인증 없이 단순 이메일만으로 처리하면 계정 탈취가 가능합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": null,
      "patternType": "claude",
      "fileTypes": ["java"],
      "category": "인증 및 세션",
      "autoFixable": false
    },
    {
      "id": "V-06",
      "title": "세션 예측",
      "description": "사용자 정의 세션 ID를 생성하면 세션 예측 공격에 취약할 수 있습니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "HttpSession.*getId.*=",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "인증 및 세션",
      "autoFixable": false
    },
    {
      "id": "V-07",
      "title": "불충분한 세션 만료",
      "description": "세션 타임아웃이 설정되지 않았거나 30분을 초과하면 세션 하이재킹 위험이 증가합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": null,
      "patternType": "xml-check",
      "xmlCheck": "session-timeout",
      "fileTypes": ["xml"],
      "category": "인증 및 세션",
      "autoFixable": true,
      "autoFixTemplate": "<session-config><session-timeout>20</session-timeout></session-config>"
    },
    {
      "id": "V-08",
      "title": "자동화 공격",
      "description": "폼에 CAPTCHA 또는 요청 제한이 없으면 자동화 공격에 취약합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": null,
      "patternType": "claude",
      "fileTypes": ["java", "jsp"],
      "category": "입력데이터 검증",
      "autoFixable": false
    },
    {
      "id": "V-09",
      "title": "프로세스 검증 누락",
      "description": "다단계 폼 처리 시 서버 측 단계 검증이 없으면 프로세스 우회가 가능합니다.",
      "severity": "info",
      "tier": "T3",
      "pattern": null,
      "patternType": "claude",
      "fileTypes": ["java"],
      "category": "입력데이터 검증",
      "autoFixable": false
    },
    {
      "id": "V-10",
      "title": "파일 다운로드 취약점",
      "description": "사용자 입력값을 직접 파일 경로에 사용하여 다운로드하면 임의 파일 다운로드가 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "new File\\(.*request\\.getParameter",
      "patternType": "regex",
      "fileTypes": ["java", "jsp"],
      "category": "입력데이터 검증",
      "autoFixable": false
    },
    {
      "id": "V-11",
      "title": "관리자 페이지 노출",
      "description": "관리자 페이지(/admin, /manager, /console)가 인증 없이 접근 가능하면 위험합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "url-pattern>.*(/(admin|manager|console))",
      "patternType": "regex",
      "fileTypes": ["xml", "java"],
      "category": "인증 및 세션",
      "autoFixable": false
    },
    {
      "id": "V-12",
      "title": "위치 공개",
      "description": "서버 버전이나 경로 정보가 에러 메시지나 헤더를 통해 노출됩니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "Server:\\s|server\\.info|getServerInfo",
      "patternType": "regex",
      "fileTypes": ["java", "xml", "properties"],
      "category": "정보 노출",
      "autoFixable": false
    },
    {
      "id": "V-13",
      "title": "쿠키 변조",
      "description": "쿠키에 SameSite 속성이 없으면 CSRF 공격에 취약합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "new Cookie\\(|addCookie\\(",
      "patternType": "regex",
      "negativePattern": "SameSite",
      "fileTypes": ["java"],
      "category": "인증 및 세션",
      "autoFixable": false
    },
    {
      "id": "V-14",
      "title": "취약한 서드파티 컴포넌트 (A06:2025)",
      "description": "알려진 취약 버전의 라이브러리 사용이 감지되었습니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "(struts2?-core|log4j-core|commons-collections).*['\"]\\d",
      "patternType": "regex",
      "fileTypes": ["xml", "gradle"],
      "category": "OWASP A06",
      "autoFixable": false
    },
    {
      "id": "V-15",
      "title": "보안 설정 오류 (A05:2025)",
      "description": "Spring Security에서 민감 경로에 permitAll 또는 CORS 와일드카드가 설정되어 있습니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "(permitAll|allowedOrigins\\(\"\\*\"|cors\\(\\)\\.configurationSource)",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "OWASP A05",
      "autoFixable": false
    },
    {
      "id": "V-16",
      "title": "서버사이드 요청 위조 SSRF (A10:2021)",
      "description": "사용자 입력 URL로 서버 측 요청을 수행하면 SSRF 공격이 가능합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "URL\\(.*request\\.|openConnection\\(\\).*request\\.",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "OWASP A10",
      "autoFixable": false
    },
    {
      "id": "V-17",
      "title": "HTTPS 미강제",
      "description": "web.xml에 CONFIDENTIAL transport-guarantee가 설정되지 않으면 평문 통신이 가능합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": null,
      "patternType": "xml-check",
      "xmlCheck": "transport-guarantee",
      "fileTypes": ["xml"],
      "category": "전송 보안",
      "autoFixable": true,
      "autoFixTemplate": "<user-data-constraint><transport-guarantee>CONFIDENTIAL</transport-guarantee></user-data-constraint>"
    },
    {
      "id": "V-18",
      "title": "불필요한 HTTP 메서드",
      "description": "PUT, DELETE 등 불필요한 HTTP 메서드가 제한되지 않으면 악용될 수 있습니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "http-method-omission|http-method>",
      "patternType": "regex",
      "fileTypes": ["xml"],
      "category": "전송 보안",
      "autoFixable": false
    },
    {
      "id": "V-19",
      "title": "X-Frame-Options 미설정",
      "description": "X-Frame-Options 또는 frame-options가 설정되지 않으면 클릭재킹 공격에 취약합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "(X-Frame-Options|frameOptions|frame-options)",
      "patternType": "regex",
      "negativeCheck": true,
      "fileTypes": ["java", "xml"],
      "category": "보안 헤더",
      "autoFixable": false
    },
    {
      "id": "V-20",
      "title": "Content-Security-Policy 미설정",
      "description": "CSP 헤더가 설정되지 않으면 XSS 및 데이터 삽입 공격에 취약합니다.",
      "severity": "info",
      "tier": "T2",
      "pattern": "Content-Security-Policy|contentSecurityPolicy",
      "patternType": "regex",
      "negativeCheck": true,
      "fileTypes": ["java", "xml"],
      "category": "보안 헤더",
      "autoFixable": false
    },
    {
      "id": "V-21",
      "title": "HSTS 미설정",
      "description": "Strict-Transport-Security 헤더가 설정되지 않으면 다운그레이드 공격에 취약합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "Strict-Transport-Security|httpStrictTransportSecurity",
      "patternType": "regex",
      "negativeCheck": true,
      "fileTypes": ["java", "xml"],
      "category": "보안 헤더",
      "autoFixable": false
    },
    {
      "id": "V-22",
      "title": "Spring Security CSRF 비활성화",
      "description": "Spring Security에서 CSRF 보호를 비활성화하면 CSRF 공격에 취약합니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "csrf\\(\\)\\.disable\\(\\)|csrf\\(csrf\\s*->\\s*csrf\\.disable\\(\\)\\)|csrf\\(AbstractHttpConfigurer::disable\\)",
      "patternType": "regex",
      "fileTypes": ["java"],
      "category": "인증 및 세션",
      "autoFixable": false
    }
  ]
}
