{
  "version": "2026.1",
  "standard": "웹 표준 준수 점검",
  "lastUpdated": "2026-03-26",
  "source": "https://www.w3.org/standards/webdesign/",
  "rules": [
    {
      "id": "W-01",
      "title": "비표준 태그 사용",
      "description": "font, center, marquee, blink, strike, big, tt 등 폐기된 HTML 태그를 사용하면 안 됩니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "<(font|center|marquee|blink|strike|big|tt)[\\s>]",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "폐기 요소",
      "autoFixable": false
    },
    {
      "id": "W-02",
      "title": "미닫힌 태그",
      "description": "HTML 태그가 올바르게 닫히지 않으면 파싱 오류가 발생합니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "<(div|span|p|ul|ol|li|table|tr|td|th|form|section|article|nav|aside|header|footer|main)\\b[^>]*>",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "마크업 유효성",
      "autoFixable": false
    },
    {
      "id": "W-03",
      "title": "DOCTYPE 누락",
      "description": "HTML 문서 첫 줄에 DOCTYPE 선언이 있어야 합니다. 누락 시 쿼크 모드로 렌더링됩니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "<!DOCTYPE",
      "patternType": "regex",
      "fileTypes": ["html", "jsp"],
      "category": "문서 구조",
      "autoFixable": false
    },
    {
      "id": "W-04",
      "title": "인라인 이벤트 핸들러",
      "description": "onclick, onmouseover 등 인라인 이벤트 핸들러 대신 addEventListener를 사용해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "on(click|mouseover|mouseout|focus|blur|change|submit|load)\\s*=",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "이벤트 처리",
      "autoFixable": false
    },
    {
      "id": "W-05",
      "title": "div 과다 사용",
      "description": "시맨틱 태그(header, nav, main, section, article, aside, footer) 대신 div를 과도하게 사용하면 접근성과 SEO가 저하됩니다.",
      "severity": "warning",
      "tier": "T2",
      "pattern": "<div",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "시맨틱 마크업",
      "autoFixable": false
    },
    {
      "id": "W-06",
      "title": "CSS 핵 사용",
      "description": "브라우저별 CSS 핵(_property, *property)을 사용하면 유지보수가 어렵고 표준에 위배됩니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "[_*]\\w+\\s*:",
      "patternType": "regex",
      "fileTypes": ["css"],
      "category": "CSS 유효성",
      "autoFixable": false
    },
    {
      "id": "W-07",
      "title": "중복 ID",
      "description": "HTML 문서 내에서 id 속성 값은 고유해야 합니다. 중복 id는 JavaScript와 접근성에 문제를 일으킵니다.",
      "severity": "critical",
      "tier": "T1",
      "pattern": "[id]",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "마크업 유효성",
      "autoFixable": false
    },
    {
      "id": "W-08",
      "title": "비표준 속성",
      "description": "data-*, aria-* 또는 표준 HTML 속성이 아닌 커스텀 속성을 사용하면 안 됩니다.",
      "severity": "info",
      "tier": "T2",
      "pattern": "<\\w+[^>]*\\s(?!data-|aria-|class|id|style|href|src|alt|title|type|name|value|action|method|for|role|tabindex|lang|dir|hidden|disabled|readonly|required|checked|selected|multiple|placeholder|pattern|min|max|step|width|height|colspan|rowspan|target|rel|media|charset|content|http-equiv)\\w+=[\"']",
      "patternType": "regex",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "마크업 유효성",
      "autoFixable": false
    },
    {
      "id": "W-09",
      "title": "charset 선언 누락",
      "description": "문서에 문자 인코딩 선언(meta charset)이 없으면 문자가 깨질 수 있습니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "<meta[^>]*charset",
      "patternType": "regex",
      "fileTypes": ["html", "jsp"],
      "category": "문서 구조",
      "autoFixable": false
    },
    {
      "id": "W-10",
      "title": "쿼크 모드 DOCTYPE",
      "description": "유효하지 않은 DOCTYPE 선언은 브라우저를 쿼크 모드로 전환시켜 렌더링 문제를 일으킵니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "<!DOCTYPE\\s+html\\s+PUBLIC",
      "patternType": "regex",
      "fileTypes": ["html", "jsp"],
      "category": "문서 구조",
      "autoFixable": false
    },
    {
      "id": "W-11",
      "title": "인라인 스타일 사용 (style 속성)",
      "description": "요소에 직접 style 속성을 작성하면 표현과 구조가 분리되지 않아 유지보수가 어렵고, CSP(unsafe-inline) 적용을 막으며, 일관된 디자인 관리를 해칩니다. 외부 CSS 클래스로 분리해야 합니다.",
      "severity": "warning",
      "tier": "T1",
      "pattern": "[style]",
      "patternType": "css-selector",
      "fileTypes": ["html", "jsp", "vue", "ejs"],
      "category": "표현/구조 분리",
      "autoFixable": false
    }
  ]
}
